{
  "productName": "PokeRogue",
  "version": "0.4.0",
  "identifier": "com.spikehd.roguetop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PokeRogue",
        "width": 1280,
        "height": 720,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../game.dat"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/mariolopjr/RogueTop/releases/latest/download/latest.json"
      ],
